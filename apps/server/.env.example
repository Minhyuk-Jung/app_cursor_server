DATABASE_URL="file:./dev.db"
PORT=3000
HOST=0.0.0.0
CURSOR_API_KEY=
DEV_API_KEY=dev-local-key
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_SEC=3600
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
JWT_REFRESH_TTL_SEC=604800
WORKSPACE_ROOT=./workspaces
MAX_CONCURRENT_RUNS=2
AGENT_CACHE_MAX=10
QUEUE_LIMIT=100
CORS_ORIGIN=http://localhost:5173
DEFAULT_MODEL=composer-2.5
# subprocess (dev) | docker (prod 권장). production + Docker 가용 시 미설정이면 docker 자동
SANDBOX_MODE=subprocess
# production에서만: R-01 완화 subprocess 허용 (비권장)
# ALLOW_SUBPROCESS_IN_PRODUCTION=true
# SDK_SHARED_RUNTIME=false
# SDK_IN_CONTAINER=false
# SANDBOX_NETWORK_INTERNAL=false
# SDK_IN_CONTAINER=true 시 SANDBOX_DOCKER_IMAGE에 @cursor/sdk 포함 이미지 필요.
# API 키는 docker exec -e CURSOR_API_KEY 로 전달(stdin JSON에 포함하지 않음).
# SANDBOX_NETWORK_INTERNAL=true 와 동시 사용 불가(Cursor API 이그레스 필요).
# docker build -t cursor-sandbox-sdk:dev apps/server/docker/sandbox-sdk
# SDK_IN_CONTAINER=true
# SANDBOX_DOCKER_IMAGE=cursor-sandbox-sdk:dev
SANDBOX_DOCKER_IMAGE=node:22-alpine
EXEC_TIMEOUT_MS=300000
SANDBOX_MEMORY_MB=512
SANDBOX_CPUS=1
SANDBOX_IDLE_MS=600000
PREVIEW_TOKEN_TTL_SEC=3600
PREVIEW_PORT_MIN=3000
PREVIEW_PORT_MAX=9999
DEFAULT_MODEL=composer-2.5